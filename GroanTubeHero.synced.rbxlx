						<ProtectedString name="Source"><![CDATA[local function note(id, timeValue, lane, groan, pose, lightCue, crowdCue)
    return { id = id, time = timeValue, lane = lane, groan = groan, pose = pose, lightCue = lightCue, crowdCue = crowdCue }
end

