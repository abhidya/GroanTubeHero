    DeadRoom = { min = 0, max = 20 },
    UnsureCrowd = { min = 21, max = 50 },
    IntoIt = { min = 51, max = 80 },
    EncoreMode = { min = 81, max = 100 },
}

Config.ScoreGrades = {
    S = 95,
    A = 85,
    B = 70,
    C = 55,
    D = 0,
}

Config.RateLimits = {
    NoteHitPerSecond = 20,
