        AvatarPoses = { "HeroPose" },
        AudiencePacks = { "BasicCrowd" },
        StageThemes = { "SchoolBackdrop" },
        Buffs = { "CrowdWarmup" },
    },
    Equipped = {
        TubeSounds = "ClassicTube",
        StageEffects = "DefaultGlow",
        AvatarPoses = "HeroPose",
        AudiencePacks = "BasicCrowd",
        StageThemes = "SchoolBackdrop",
    },
    Upgrades = {
        Timing = 0,
        HypeGain = 0,
        Recovery = 0,
        Stagecraft = 0,
        Chaos = 0,
        Focus = 0,
